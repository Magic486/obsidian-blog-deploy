{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2020", "DOM"],
    "baseUrl": ".",
    "paths": {
      "obsidian": ["node_modules/obsidian"]
    }
  },
  "include": ["src/**/*.ts", "main.ts"],
  "exclude": ["node_modules", "dist"]
}
