{
  "name": "obsidian-blog-deploy",
  "version": "1.0.0",
  "description": "Deploy Obsidian notes to Hexo blog with one click",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production"
  },
  "keywords": ["obsidian", "plugin", "blog", "hexo", "deploy"],
  "author": "magic486",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "obsidian": "^1.4.0",
    "typescript": "^5.0.0"
  }
}
